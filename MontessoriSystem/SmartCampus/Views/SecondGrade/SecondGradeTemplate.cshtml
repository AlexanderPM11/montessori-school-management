                                    </div>
                                </td>

                                <td style="border: 1px solid #000; padding: 0px;"></td>
                            }
                            else
                            {
                                <td style="border: 1px solid #000; padding: 0px;"></td>

                                <td style="border: 1px solid #000; padding: 6px; ">
                                    <div style="height:30px; font-size:13px; font-style:italic; margin-top:0px;">
                                        <img style="width:20px;height: 25px; padding:0px; margin:0px;" src="data:image/png;base64," />
                                    </div>
                                </td>

