            margin-bottom:5px;
        }

            .image-container-1 img {
                width: 100%;
                height: 100vh;
                object-fit: cover;
            }
            
       
    </style>

</head>
<body>
    
    @* Encabezado *@

    <div class="image-container-1">
        <img src="@imgHead1" />
    </div>

   @*  <div class="image-container-2" style="@($"background-image: url('{imgHead2}');")">
    </div> *@

    @* ----------------------------------------------------------------------------------------------- *@
    
    @* Logo Inicial y Reporte para las familias *@

    <div class="container-logo-gob-rep-dom">

        <div style="position:absolute; width:200px; height:200px;   display:flex; justify-content:start; align-items:start">
            <img style="object-fit: cover;width: 100%;" src="data:image/png;base64," />

        </div>

        <divstyle ="width:100%">
            <img src="data:image/png;base64," />
        </divstyle>

        <br />
        <span style="width:100%; font-size:10px; font-weight:100;">GOBIERNO DE LA</span>
        
        <br />
        <span style="width:100%; font-size:16px; font-weight:300;">REPÚBLICA DOMINICANA</span>
        <div class="container-linea" style="width: 100%; display: flex; align-items: center; justify-content: center; margin-top:5px; margin-bottom:5px;">
