                        }

                        double avageFinal = (LenguaCFE + MatemCFE + CienciaSociCFE + CienciaNatuCFE + EducaciFisiCFE + IntegralHumanaCFE + EducaciArtiCFE) / (numberSubject);

                        if (avageFinal >= 63)
