            <div style="width:400px; font-size:32px; font-weight:bold; text-align:center; width:650px; margin: 0 auto;  line-height: 1.5;">
                <p>
                    INFORME DE APRENDIZAJE <br /> Segundo Grado del Nivel Primario 
                   
                </p>
                
            </div>
        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

