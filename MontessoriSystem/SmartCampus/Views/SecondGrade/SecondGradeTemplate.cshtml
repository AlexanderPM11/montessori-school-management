                    </span>                   
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">               
                <p style="font-size: 12px; margin: 0;">
                    ID Estudiante (Número de identificación SIGERD):
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:163px;">
                       
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Año Escolar:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:496px;">
                        @(DateTime.Now.Year) - @(DateTime.Now.Year + 1)
                    </span>
                    
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Docente:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:530px;">
                         @Model.NameTeacher
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Centro Educativo:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:455px;">
                         @Model.EducationalInstitutionViewModel.Name
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Código del Centro:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:450px;">
                         @Model.EducationalInstitutionViewModel.EducationalRegistry
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Tanda:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:553px;">
                         @Model.EducationalInstitutionViewModel.Session
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Teléfono del Centro:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:435px;">
                         @Model.EducationalInstitutionViewModel.Phone
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Distrito Educativo:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:455px;">
                        @Model.EducationalInstitutionViewModel.District
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Regional de Educación:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:410px;">
                        @Model.EducationalInstitutionViewModel.Regional
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Provincia:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:530px;">
                        @Model.NameProvince
                    </span>                    
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Municipio:
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:530px;">
                        @Model.NameMunicipality
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top:100px;">
            <div style="text-align: center;">
                <hr style="width: 400px; border: 1px solid rgb(70, 69, 69); margin-bottom: 5px;">
                <span style="font-weight: bold; font-size: 14px;">Firma del Director (a) del Centro Educativo</span>
            </div>
        </div>

        @* ----------------------------------------------------------------------------------------------- *@

        @* Presentación *@
        <div style="page-break-before: always;"></div>

        <div style="padding-left:80px;padding-right:80px; text-align: center; margin-top:0px; font-family: Arial, sans-serif; line-height: 1.5;">
           
            <div style="padding-top:50px; text-align:center;">

                <p style="font-weight: bold; font-size: 17px; margin: 0;">Presentación</p>
                <p style="font-weight: bold; font-size: 17px;text-align:start !important;"> Apreciada Familia: Madre, Padre o Tutora, Tutor.</p>
                
                <p style="font-size: 14px;text-align: justify;">
                    En este Informe compartimos contigo cómo va el proceso de aprendizaje del niño
                    o de la niña que desde tu hogar viene a la escuela con muchos sueños, con muchas
                    esperanzas para aprender y para desarrollarse plenamente, como persona digna y
                    valiosa.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    Como familia estás cumpliendo con un deber sagrado y con un derecho fundamental,
                    que es enviar puntual y diariamente tu hijo o hija a la escuela. De esta manera le
                    estás ayudando a que, a través de la educación, pueda desarrollar al máximo todo su
                    potencial, lo que, en el futuro, repercutirá positivamente en la mejora de su calidad de
                    vida.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    Ten presente que tanto en el hogar como en la escuela debemos apoyar amorosamente
                    al niño o la niña en su proceso de aprendizaje, para que pueda alcanzar sus metas, que
                    es el mayor legado que podemos brindarle.
                </p>
               
                <p style="font-size: 14px;text-align: justify;">
                    Los grados primero, segundo y tercero, que conforman el Primer Ciclo del Nivel Primario,
                    tienen como propósito propiciar el logro la alfabetización inicial en la etapa oportuna.
                    Durante esos tres años tenemos la responsabilidad de que lea correctamente cualquier
                    situación de lectura que deseen o se les presente. De igual modo, que escriban con
                    claridad sus ideas, pensamientos y sentimientos para responder a diferentes situaciones
                    de escritura. Esta es una tarea que requiere de tu seguimiento y apoyo desde la casa,
                    preparando espacios y tiempo, para la lectura y ofreciendo oportunidades para la
                    escritura. Cuando le ofrezcas regalos agrégale libros variados que incluyan valores.
                    Revisa en el Informe de Aprendizaje las competencias que debe alcanzar, para que así
                    puedas acompañar y apoyar todo el proceso junto a la escuela.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    Es importante estar pendiente de lo que aprende tu hijo o hija y lo que le falta por
                    aprender. Para eso debes revisar su Informe de Aprendizaje que recibirás al menos
                    cuatro (4) veces durante el año escolar: <strong>
                        agosto-octubre, noviembre-enero, febrero
                        marzo, abril-junio.
                    </strong>   Así tendrás la oportunidad de reforzarlo/a donde lo necesite, para
                    de esa manera superar el grado satisfactoriamente y con éxito.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    El Informe de Aprendizaje es como un cofre donde se van registrando los tesoros que
                    tu hijo o hija va descubriendo cada día, desde la escuela. En otras palabras, es donde
                    se te informa del proceso que va desarrollando respecto a lo que debe aprender en el
                    grado. Por tanto, para obtener los mejores aprendizajes se necesita tu apoyo y estímulo
                    permanente.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    Los resultados de los trabajos, ejercicios de evaluación o tareas que realiza tu hijo o hija
                    expresan en qué medida va adquiriendo las competencias específicas. Estos pueden
                    expresarse a través de una escala de calificación cualitativa (descriptiva) o cuantitativa
                    (números). Con la adecuación curricular se asume una escala de valoración, como se
                    muestra a continuación:
                </p>
                
            </div>

        </div>  

        @* -------Numero Page----------*@

        <div style="font-size:8px; position: relative; bottom: 0; right:0; width: 100%; text-align: right; font-family: Arial, sans-serif; padding: 10px; padding-top:20px; padding-bottom:20px;">
            <span style="font-size:12px !important; padding-right:60px;">3</span>
        </div>

        @* ----------------------------------------------------------------------------------------------- *@

        <div style="page-break-before: always;"></div>

        <div style="padding-left:60px;padding-right:60px; text-align: center; padding-top:100px; line-height: 1.5;">

            <div style="padding-top:00px; text-align:center;padding-left:7px; ">

                <p style="font-weight: bold;text-align:start; font-size: 16px; margin: 0; margin-bottom:10px;"> Escala de valoración</p>

                <div class="" style="width:600px; margin: 0px auto;">

                    <table style="width: 100%; border-collapse: collapse; font-family: Arial, sans-serif; font-size: 12px; text-align: left;">
                        <thead>
                            <tr style="background-color: #f2f2f2; border: 1px solid #000;">
                                <th style="padding: 4px; border: 1px solid #000; width: 25%;">Escala numérica</th>
                                <th style="padding: 4px; border: 1px solid #000; width: 25%;">Escala literal</th>
                                <th style="padding: 4px; border: 1px solid #000; width: 50%;">Descripción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr style="border: 1px solid #000;">
                                <td style="padding: 8px; border: 1px solid #000;">91-100</td>
                                <td style="padding: 8px; border: 1px solid #000;">(S) Sobresaliente</td>
                                <td style="padding: 8px; border: 1px solid #000;">Ha superado de manera destacada los aprendizajes esperados.</td>
                            </tr>
                            <tr style="border: 1px solid #000;">
                                <td style="padding: 8px; border: 1px solid #000;">80-90</td>
                                <td style="padding: 8px; border: 1px solid #000;">(L) Logrado</td>
                                <td style="padding: 8px; border: 1px solid #000;">Ha logrado satisfactoriamente los aprendizajes esperados.</td>
                            </tr>
                            <tr style="border: 1px solid #000;">
                                <td style="padding: 8px; border: 1px solid #000;">70-79</td>
                                <td style="padding: 8px; border: 1px solid #000;">(P) En Proceso</td>
                                <td style="padding: 8px; border: 1px solid #000;">Muestra avances de los aprendizajes esperados, pero aún le falta alcanzar el nivel esperado.</td>
                            </tr>
                            <tr style="border: 1px solid #000;">
                                <td style="padding: 8px; border: 1px solid #000;">63-69</td>
                                <td style="padding: 8px; border: 1px solid #000;">(I) Iniciado</td>
                                <td style="padding: 8px; border: 1px solid #000;">Ha logrado el nivel mínimo de los aprendizajes esperados.</td>
                            </tr>
                            <tr style="border: 1px solid #000;">
                                <td style="padding: 8px; border: 1px solid #000;">62 o menos</td>
                                <td style="padding: 8px; border: 1px solid #000;">(N) No alcanzado</td>
                                <td style="padding: 8px; border: 1px solid #000;">No ha alcanzado el mínimo de los aprendizajes esperados, presenta dificultades para el desarrollo de sus actividades.</td>
                            </tr>
                        </tbody>
                    </table>


                </div>

                <p style="text-align:justify; font-size: 14px; margin-bottom:10px;">
                    Cuando tu hijo o hija no ha participado en el proceso de enseñanza-aprendizaje durante el
                    período por alguna situación de movilidad (cambio a otro centro o comunidad), enfermedad,
                    ingreso tardío, entre otras; se coloca <strong>(NE)</strong>No evaluado, en la casilla correspondiente.
                </p>
                <p style="text-align:justify; font-size: 14px; margin-bottom:10px;">
                    Al recibir el Informe de Aprendizaje podrás notar que el nivel de logro de las competencias
                    en cada período se expresa en escala numérica y el resultado final de la asignatura se expresa
                    de forma numérica con su representación literal.
                </p>
               
                <p style="text-align:justify; font-size: 14px; margin-bottom:10px;">
                    Apreciada familia, contamos contigo, ya que educar es un proceso de responsabilidad
                    conjunta tanto dentro como fuera de la escuela. Si en algún momento observas que algo no
                    va bien con tu hijo o hija, acércate a la escuela para que juntos y juntas podamos analizarlo
                    y resolverlo. Está comprobado que todo niño y toda niña puede superar los obstáculos que
                    se le presentan en el camino, para hacer realidad sus ideales, sus sueños de superación y sus
                    metas proyectadas.
                </p>
                <p style="text-align:justify; font-size: 14px; margin-bottom:10px;">
                   <strong>MUCHAS FELICIDADES POR LOS APRENDIZAJES Y POR LOS LOGROS ALCANZADOS POR
                    TU HIJO E HIJA.</strong> Acompáñales en su proceso formativo con alegría, motívales con fe y con
                    mucha confianza en sus extraordinarias posibilidades. Tu hija o tu hijo cuentan contigo en
                    esta preciosa aventura de aprender.
                </p>
                <p style="text-align:justify; font-size: 14px; margin-bottom:10px;">
                    <strong>
                        Nunca lo olvides: La escuela tiene, siempre, sus puertas abiertas para tu hijo o hija y para
                        ti ¡TE ESPERAMOS!
                    </strong>
                </p>
                <p style="font-size: 14px; margin-top:20px;">
                    <strong>
                         Ministerio de Educación de la República Dominicana
                    </strong>
                </p>

                <div style=" font-size:8px; position: relative; bottom: 0; width: 100%; text-align: left; font-family: Arial, sans-serif;padding: 10px; padding-top:60px;">
                    <span style="font-size:12px !important;  padding-right:10px;">4</span>
                </div>

            </div>

        </div>

        

        <div style="page-break-before: always;"></div>

        <div style="padding-left:60px;padding-right:60px; text-align: center; padding-top:100px; line-height: 1.5;">

            <div style="padding-top:350px; text-align:center;padding-left:7px; ">
               <p style="font-size:30px;  font-weight:bold;">
                    INFORME DE EVALUACIÓN
                    DE LOS APRENDIZAJES
                    POR ÁREA CURRICULAR
               </p>
            </div>
            <div style=" font-size:8px; position: relative; bottom: 0; width: 100%; text-align: left; font-family: Arial, sans-serif;padding: 10px; padding-top:350px;">
                <span style="font-size:12px !important;  padding-right:10px;">5</span>
                
            </div>

        </div>


        @* Pagina #6 *@

        <div style="page-break-before: always;"></div>

        <div style="padding-left:40px;padding-right:30px; text-align: center; margin-top:5px; padding-top:20px; line-height: 1.5;">

            <div style="padding-top:00px; text-align:center;padding-left:7px;">

                <div>

                    <table border="1" style="border-collapse: collapse; font-family: Arial, sans-serif; font-size: 11px; text-align: center;">
                        <thead>
                            <tr>
                                <th colspan="10" style="text-align: center; padding: 4px;">Área: Lengua Española</th>
                            </tr>
                            <tr>
                                <th colspan="2" rowspan="2" style="text-align: center; padding: 4px;">COMPETENCIAS FUNDAMENTALES Y ESPECÍFICAS DEL GRADO</th>
                                <th colspan="4"  style="padding-left:8px; padding-right:8px;" >Calificación por periodo</th>
                                <th colspan="2" style="padding-left:6px; padding-right:6px;" rowspan="2">Promedio</th>
                                <th colspan="2">Resultado del área</th>
                            </tr>
                            <tr>
                                <th style="padding-left:12px; padding-right:12px;">P1</th>
                                <th style="padding-left:12px; padding-right:12px;">P2</th>
                                <th style="padding-left:12px; padding-right:12px;">P3</th>
                                <th style="padding-left:12px; padding-right:12px;">P4</th>
                                <th style="padding-left:9px; padding-right:9px;">C.F.E.</th>
                                <th style="padding-left:9px; padding-right:9px;">Literal</th>
                            </tr>
                        </thead>

                        <tbody>

                            @{
                                int index = 1;

                                // Variables para las calificaciones (nota) de cada materia
                                double LenguaCFE = 0;
                                double MatemCFE = 0;
                                double CienciaSociCFE = 0;
                                double CienciaNatuCFE = 0;
                                double EducaciFisiCFE = 0;
                                double IntegralHumanaCFE = 0;
                                double EducaciArtiCFE = 0;


                                bool Promovido = false;
                                bool AllPeriodCompleteOne = false;

                                string GetLiteral(double average)
                                {
                                    if (average >= 91)
                                        return "S";
                                    else if (average >= 80)
                                        return "L";
                                    else if (average >= 70)
                                        return "P";
                                    else if (average >= 62)
                                        return "I";
                                    else
                                        return "N";
                                }
                            }

                            @foreach (var item in Model.vmPrinc.Take(3))
                            {
                                <tr>
                                    <td style="padding: 8px;">@($"C{index}")</td>
                                    <td style="padding: 8px; text-align: left;">
                                        @Html.Raw(item.Indicator.Description)
                                    </td>

                                    @{
                                        var firstPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Agosto_Octubre));
                                        var secondPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Noviembre_Enero));
                                        var thirdPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Febrero_Marzo));
                                        var fourPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Abril_Junio));

                                        bool allPeriodCompleted = firstPeriod != null && secondPeriod != null && thirdPeriod != null && fourPeriod != null;
                                        double average = 0;

                                        if (allPeriodCompleted)
