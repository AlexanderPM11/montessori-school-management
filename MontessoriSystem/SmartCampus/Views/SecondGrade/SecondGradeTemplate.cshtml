                        @(Model.StudentViewModel.Name )
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 12px; margin: 0;">
                    Apellido (s):
                    <span style="border-bottom:1px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 12px; display: inline-block; width:500px;">
