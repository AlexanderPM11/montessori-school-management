        overflow-x: visible;
        /* width:100px; */
    }
    #radio-no{
        margin-left: 30px;
    }
    .form-check {
        padding-left: 1.6rem !important;
    }
    .container-btn{
        margin-top:30px;
        width:100%;
        display: flex;
        justify-content: end;
        right: 215px;
    }
    #btn-save-student{
        margin-right:10px;
    }

    #btn-add-seen-room {
        margin-left:10px;
    }

    .container-btn-seacrh{

        margin-left:10px
    }

    .container-filter{
        display:flex;
        justify-content:end;
        padding-right: 33px;
        width: 100%;
        margin-bottom: 30px;
    }
    li{
        cursor:pointer;
    }


    /* Responsive */
     .btn-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        padding-bottom: 10px;
        margin-top: 10px;
        margin-right: 10px;
    }

