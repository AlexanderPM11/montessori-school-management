@using MontessoriSystem.Core.Application.ViewModels.User;
@using MontessoriSystem.Core.Application.ViewModels.Department;
@model DepartmentSaveViewModel


@{
    ViewData["Title"] = "Users";
}

<div class="container mb-1 ">

    <div class="container-principal">

        <div class="btn-container">           

            <button type="button" id="newDepartment" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nuevo</button>
            <button type="button" disabled id="editDepartment" class="btn btn-warning"><i class="fa-solid fa-pen-to-square"></i> Editar</button>
            <button type="button" disabled id="deleteDepartment" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Eliminar</button>

        </div>
        <div id="gridContainerDepartment"></div>
    </div>
    

</div>


<script>

    var idDepartment='';

    $(document).ready(function () {
       
        GetDatosUserJson()
    });

    //Cargar table listado estudiantes
    function GetDatosUserJson() {
        
        $('#gridContainerDepartment').dxDataGrid({
            dataSource: {
                load: function () {
                    return $.ajax({
                        url: '@Url.Action("GetdepartmentsJson", "Department")',
                        dataType: "json"
                    });
                }
            },
            paging: {
                pageSize: 10,
            },
            pager: {
                showPageSizeSelector: true,
                allowedPageSizes: [10, 25, 50, 100],
            },
            searchPanel: {
                visible: true,
                highlightCaseSensitive: true,
            }, scrolling: {
                mode: 'standard', // 'virtual' o 'standard'
                // Otros ajustes de desplazamiento si es necesario
            },
            groupPanel: { visible: true },
            grouping: {
                autoExpandAll: false,
            },
            allowColumnReordering: true,
            keyExpr: 'ID',
            showColumnLines: true,
            showRowLines: true,
            rowAlternationEnabled: false,
            showBorders: true,
            hoverStateEnabled: true,
            selection: {
                mode: 'multiple',
            },
            width: '100%',
            columns: [
                {
                    dataField: 'name',
                    caption: "Nombre"
                },
                {
                    dataField: 'description',
                    caption: "Descripción"
                }

            ],
            onRowDblClick: function (e) {
                CreateUpdate();
            }, onRowClick: function (e) {
                idDepartment =e.data.id
                //activeBtn()
            },
            onSelectionChanged(selectedItems) {

                var selectedRowKeys = selectedItems.selectedRowKeys;
                if (selectedRowKeys.length === 1) {
                    idDepartment = selectedRowKeys[0].id;
                    activeBtn()
                } else {
                    disableBtn();
                }
            },
            onContentReady: function (e) {

            }
        });

    }  


    //Functions   

    $('#newDepartment').on('click', function () {
        idDepartment = '';        
        CreateUpdate('green', 'Crear Usuario');
    })
    $('#editDepartment').on('click', function () {
        CreateUpdate();
    })
    $('#deleteDepartment').on('click', function () {
        DeleteDeparment();
    })

    function CreateUpdate(type = 'green', title = 'Actualizar Usuario') {

        $.ajax({            
            url: '@Url.Action("CreateUpdate", "Department")',
            method: 'GET',
            data: {id: idDepartment },
            success: function (data) {
                confirmDailog = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: "",
                    content: data,
                    type: "green",
                    typeAnimated: true
                });
            }
        });

    }
    
    function DeleteDeparment(type = 'green', title = 'Actualizar Usuario') {

        $.confirm({
            typeAnimated: true,
            type: 'red',
            icon: 'fa fa-exclamation-circle',
            title: 'Confirmar Eliminación',
            content: '¿Está seguro de que desea eliminar este Departamento?',
            buttons: {
                Confirmar: {
                    text: 'Sí, eliminar',
                    btnClass: 'btn-red',
                    action: function () {
                        DeleteSchedule();
                    }
                },
                Cancelar: {
                    text: 'Cancelar',
                    btnClass: 'btn-default'
                }
            }
        });

    }

    function DeleteSchedule() {
        showGlobalLoadingIndicator();
        $.ajax({
            url: '@Url.Action("Delete", "Department")',
            method: 'Post',
            data: { id: idDepartment },
            success: function (data) {
                hideGlobalLoadingIndicator();
                if (data.result) {
                    toastr.success(data.data, 'Correcto!');
                    refresshGridDepartments();
                    disableBtn();
                } else {
                    toastr.error(data.data, 'Error!');
                }
            }
        });

    }

    function refresshGridDepartments() {

        $("#loadPanelContainer").dxLoadPanel("show");

        var dataGrid = $("#gridContainerDepartment").dxDataGrid("instance");
        dataGrid.refresh().done(function () {
            $("#loadPanelContainer").dxLoadPanel("hide");
        });
    }


    // btns Enable disable
    function activeBtn() {
        $('#editDepartment').prop("disabled", false);
        $('#deleteDepartment').prop("disabled", false);
    }

    function disableBtn() {
        $('#editDepartment').prop("disabled", true);
        $('#deleteDepartment').prop("disabled", true);
    }


</script>

<style>
    .btn-container {
        display: flex;
        justify-content: end;
        padding-bottom: 10px;
        min-width: 200px;
    }

    .container-principal {
        background-color: white;
        border-radius: 5px;
        padding: 30px;
        margin-bottom: 30px;
        -webkit-box-shadow: 1px 1px 5px 0px rgba(0, 0, 0, 0.3);
        box-shadow: 1px 1px 5px 0px rgba(0, 0, 0, 0.3);
        border: 1px solid #ccd2d5;
    }

    #editDepartment {
        margin-left: 10px;
        margin-right: 10px;
    }

    #deleteUser {
        margin-left: 10px;
        margin-right: 10px;
    }
</style>

