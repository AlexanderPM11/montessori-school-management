
<div class="text-center">


    <div class="btn-container">
        <button type="button" id="btnNewsExten" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nuevo</button>
        <button type="button" disabled id="btnEditExten" class="btn btn-warning"><i class="fa-solid fa-pen-to-square"></i> Editar</button>
        <button type="button" disabled id="btnTeachersInstituExt" class="btn btn-aqua-green"><i class="fa-solid fa-person-chalkboard"></i> Profesores</button>

        <button type="button" disabled id="btnParentsInstituExt" class="btn btn-custom-Blue-Steel">
            <i class="fa-solid fa-person-breastfeeding"></i> Padres
        </button>
        <button type="button" disabled id="btnStdentInstituExt" class="btn btn-info"><i class="fa-solid fa-user-graduate"></i> Estudiantes</button>
        @* <button type="button" disabled id="btnUsersInstituExt" class="btn btn-info"><i class="fa-solid fa-users"></i> Usuarios</button> *@
        <button type="button" disabled id="BtnRoomExten" class="btn btn-primary"><i class="fa-solid fa-house-user"></i> Salones</button>
        <button type="button" disabled id="btnGradeExten" class="btn btn-light"><i class="fa-solid fa-person-chalkboard"></i> Grados</button>
        <button type="button" disabled id="btnSujectExten" class="btn btn-success"><i class="fa-solid fa-book-open-reader"></i> Asignatura</button>       
        <button type="button" disabled id="btnPeriodExten" class="btn btn-secondary"><i class="fa-regular fa-calendar-days"></i> Periodos Lectivos</button>
    </div>
    <div id="gridContainerHeadquarters"></div>


</div>

<script>


$(document).ready(function() {

    var idInstitu = 0;
    GetHeadquartersJson();
       
});
    var idInstituHeadquarters = @ViewBag.idInstitu;

    function GetHeadquartersJson() {

        $('#gridContainerHeadquarters').dxDataGrid({
            dataSource: {
                load: function () {
                    
                    return $.ajax({
                        url: '@Url.Action("GetHeadquartersJson", "EducationalInstitution")',
                        data: { idInstitu: idInstituHeadquarters, institutionIdPrincipal: idInstituMain },
                        dataType: "json"
                    });
                }
            },
            paging: {
                pageSize: 10,
            },
            columnMinWidth: 160,
            pager: {
                showPageSizeSelector: true,
                allowedPageSizes: [10, 25, 50, 100],
            },
            searchPanel: {
                visible: true,
                highlightCaseSensitive: true,
            }, scrolling: {
                mode: 'standard', // 'virtual' o 'standard'
                // Otros ajustes de desplazamiento si es necesario
            },
            groupPanel: { visible: true },
            grouping: {
                autoExpandAll: false,
            },
            allowColumnReordering: true,
            keyExpr: 'ID',
            showColumnLines: true,
            showRowLines: true,
            rowAlternationEnabled: false,
            showBorders: true,
            hoverStateEnabled: true,
            selection: {
                mode: 'multiple',
            },
            width: '100%',
            columns: [
                {
                    dataField: 'name',
                    caption: "Nombre"
                },
                {
                    dataField: 'address',
                    caption: "Dirección"
                },
                {
                    dataField: 'department',
                    caption: "Departamento"
                },
                {
                    dataField: 'city',
                    caption: "Ciudad"
                },
                {
                    dataField: 'phone',
                    caption: "Teléfono"
                },
                {
                    dataField: 'mobile',
                    caption: "Móvil"
                },
                {
                    dataField: 'nameRector',
                    caption: "Rector"
                }, 
                {
                    dataField: 'nameAdmin',
                    caption: "Administrador"
                },
                {
                    dataField: 'nameCordinator',
                    caption: "Cordinador"
                }
                ,
                {
                    dataField: 'nameSecretary',
                    caption: "Secretario/a"
                }
                ,
                {
                    dataField: 'academicResolution',
                    caption: "Resolución Académica"
                }
                ,
                {
                    dataField: 'educationalRegistry',
                    caption: "Registro Educativo"
                }
                ,
                {
                    dataField: 'website',
                    caption: "Sitio Web"
                }

            ],

            onRowDblClick: function (e) {
                CreateUpdatenstitu()
            }, 

            onRowClick: function (e) {
                idInstitu = e.data.id
            },

            onSelectionChanged(selectedItems) {
               
                var selectedRowKeys = selectedItems.selectedRowKeys;
                if (selectedRowKeys.length === 1) {
                    idInstitu = selectedRowKeys[0].id;
                    activeBtnExten();
                } else {
                    disableBtnExten();
                }
            },

            onContentReady: function (e) {

            }, 
            export: {
                enabled: true,
                formats: ['pdf'],
                allowExportSelectedData: true,
            },

            onExporting(e) {
                const doc = new jsPDF();

                DevExpress.pdfExporter.exportDataGrid({
                    jsPDFDocument: doc,
                    component: e.component,
                    indent: 5,
                }).then(() => {
                    doc.save('Students.pdf');
                });
            },
        });

    }

    function CreateUpdatenstitu() {
       
        $.ajax({
            url: '@Url.Action("CreateUpdate", "EducationalInstitution")',
            method: 'GET',
            data: { idInstitu, institutionIdPrincipal: idInstituMain },
            success: function (data) {
                confirmDailog = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: '',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });

    }

    function getTeachingPeriodsExten() {
        
        $.ajax({
            url: '@Url.Action("TeachingPeriods", "TeachingPeriod")',
            method: 'GET',
            data: { idInstitu },
            success: function (data) {
                var confirmDailogTeaching = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: 'Periodos Lectivos',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });
    }
    
    function getRooms() {
        
        $.ajax({
            url: '@Url.Action("Rooms", "Room")',
            method: 'GET',
            data: { idInstitu },
            success: function (data) {
                var confirmDailogTeaching = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: 'Salones',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });
    }

    function getSuject() {
        
        $.ajax({
            url: '@Url.Action("Sujects", "Suject")',
            method: 'GET',
            data: { idInstitu },
            success: function (data) {
                var confirmDailogTeaching = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: 'Asignaturas',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });
    }
    
    function getGradesExt() {
       
        $.ajax({
            url: '@Url.Action("Grades", "Grade")',
            method: 'GET',
            data: { idInstitu },
            success: function (data) {
                var confirmDailogTeaching = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: 'Grados',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });
    }

    function getUsersInstituExt() {
       
        $.ajax({
            url: '@Url.Action("PartialViewUsers", "User")',
            method: 'GET',
            data: { idInstitu, institutionIdPrincipal: idInstituMain },
            success: function (data) {
                var confirmDailogTeaching = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: 'Usuarios',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            },
            error: function (error) {
                console.error('Error al obtener datos:', error);
            }
        });

    }
    function getTeachersExt() {

        $.ajax({
            url: '@Url.Action("PartialViewUsers", "Teacher")',
            method: 'GET',
            data: { idInstitu },
            success: function (data) {
                confirmDailog = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: 'Información de los Profesores',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });

    }
    function getParentsExt() {

        $.ajax({
            url: '@Url.Action("PartialViewUsers", "Parents")',
            method: 'GET',
            data: { idInstitu },
            success: function (data) {
                confirmDailog = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: 'Información Familiar del Estudiante',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });

    }
    // Btns actions
    $("#btnNewsExten").click(function (event) {
        event.preventDefault();
        disableBtnExten();
        deselectAllRowsExt();
        idInstitu = 0;
        CreateUpdatenstitu();
    });

    $("#btnEditExten").click(function (event) {
        event.preventDefault();
        CreateUpdatenstitu();       
    });

    $("#btnPeriodExten").click(function (event) {
        event.preventDefault();
        getTeachingPeriodsExten();
    });

    $("#BtnRoomExten").click(function (event) {
        event.preventDefault();
        getRooms();
    });
    $("#btnSujectExten").click(function (event) {
        event.preventDefault();
        getSuject()
    });
    $("#btnGradeExten").click(function (event) {
        event.preventDefault();
        getGradesExt()
    });

    $("#btnUsersInstituExt").click(function (event) {
        event.preventDefault();
        getUsersInstituExt();
    });

    $("#btnStdentInstituExt").click(function (event) {
        event.preventDefault()
        getStudentExt();
    });
    $("#btnParentsInstituExt").click(function (event) {
        event.preventDefault()
        getParentsExt();
    });
    $("#btnTeachersInstituExt").click(function (event) {
        event.preventDefault()
        getTeachersExt();
    });
    
    
    function getStudentExt() {

        $.ajax({
            url: '@Url.Action("GetStudent", "Student")',
            method: 'GET',
            data: { idInstitu },
            success: function (data) {
                var confirmDailogTeaching = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: 'Estudiantes',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });

    }
    function activeBtnExten() {
        $('#btnEditExten').prop("disabled", false);
        $('#btnSujectExten').prop("disabled", false);
        $('#BtnRoomExten').prop("disabled", false);
        $('#btnPeriodExten').prop("disabled", false);
        $('#btnGradeExten').prop("disabled", false);
        $('#btnUsersInstituExt').prop("disabled", false);
        $('#btnStdentInstituExt').prop("disabled", false);
        $('#btnParentsInstituExt').prop("disabled", false);
        $('#btnTeachersInstituExt').prop("disabled", false);
    }

    function disableBtnExten() {
        $('#btnEditExten').prop("disabled", true);
        $('#btnSujectExten').prop("disabled", true);
        $('#btnSujectExten').prop("disabled", true);
        $('#btnUsersInstituExt').prop("disabled", true);
        $('#BtnRoomExten').prop("disabled", true);
        $('#btnPeriodExten').prop("disabled", true);
        $('#btnGradeExten').prop("disabled", true);
        $('#btnStdentInstituExt').prop("disabled", true);
        $('#btnParentsInstituExt').prop("disabled", true);
        $('#btnTeachersInstituExt').prop("disabled", true);
    }

    function deselectAllRowsExt() {
        var dataGrid = $('#gridContainerHeadquarters').dxDataGrid('instance');
        dataGrid.clearSelection();
    }



</script>

<style>
    .btn-container {
        display:flex;
        justify-content:end;
        padding-bottom: 10px;
        min-width: 200px;
    }

    #btnNewsExten{
        margin-left: 10px;
    }

    #BtnRoomExten {
        margin-right: 10px;
    }

    #btnStdentInstituExt {
        margin-right: 10px;
    }

    #btnEditExten {
        margin-left: 10px;
        margin-right: 10px;
    }


    #btnSujectExten {
        margin-right: 10px;
        margin-left: 10px;
    }

    #btnUsersInstituExt {
        margin-right: 10px;
    }

    #btnTeachersInstituExt {
        margin-right: 10px;
    }

    #btnParentsInstituExt {
        margin-right: 10px;
    }

</style>
