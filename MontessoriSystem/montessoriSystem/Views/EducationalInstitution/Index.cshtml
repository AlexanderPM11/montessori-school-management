        showGlobalLoadingIndicator();
        var idInstitu = idInstituMain;        
        $.ajax({
            url: '@Url.Action("Grades", "Grade")',
            method: 'GET',
            data: { idInstitu },
            success: function (data) {
                hideGlobalLoadingIndicator();
                var divCont = '<div id="container-data">' + data + '</div>';

                var confirmDailogTeaching = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: 'Grados',
                    content: divCont,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });
    }
   
