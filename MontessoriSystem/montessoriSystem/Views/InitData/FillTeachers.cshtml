@{
    ViewData["Title"] = "Profesores";
}

<div class="container mt-5">
    <div class="card shadow-lg">
        <div class="card-header d-flex align-items-center" style="background-color: #007bff; color: white;">
            <img src="~/Img/default_teacher.png" class="rounded-circle mr-3" alt="Profesores" /> <!-- Imagen representativa -->
            <h5 class="card-title mb-0 ml-2" style="color: white;">Subir Archivo Excel - Profesores</h5>
        </div>
        <div class="card-body">
            <form id="uploadFormTeacher" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="excelFileTeacher" class="btn btn-outline-primary w-100">Seleccionar Archivo</label>
                    <input type="file" class="form-control-file d-none" id="excelFileTeacher" name="excelFileTeacher" accept=".xlsx, .xls" />

                    <!-- Campo para mostrar el nombre del archivo seleccionado -->
                    <input type="text" class="form-control mt-2" id="fileNameDisplayTeacher" placeholder="No hay archivo seleccionado" readonly />
                </div>

                <div class="text-center">
                    <button type="button" id="downloadTemplateExcelTeacher" class="btn btn-info mt-3 mr-2"><i class="fa fa-download"></i> Descargar Plantilla</button>
                    <button type="button" id="uploadBtnExcelTeacher" class="btn btn-success mt-3 mr-2"><i class="fa fa-upload"></i> Subir Archivo</button>
                    <button type="button" id="resetBtn" class="btn btn-danger mt-3"><i class="fa fa-redo"></i> Resetear</button>
                </div>
            </form>
            <div id="resultTeacher" class="mt-4 text-center"></div>
        </div>
    </div>
</div>

<!-- Estilos adicionales para mejorar la apariencia -->
<style>
    .card-title {
        color: white !important;
    }

    .card {
        border-radius: 15px;
        overflow: hidden;
    }

    .card-header {
        display: flex;
        align-items: center;
        background-color: #007bff;
        color: white;
        border-bottom: 3px solid #0056b3;
    }

        .card-header img {
            border-radius: 50%;
            width: 50px;
            height: 50px;
            margin-right: 15px;
        }

    .btn {
        font-weight: bold;
        transition: transform 0.2s ease-in-out;
    }

        .btn:hover {
            transform: scale(1.05);
        }
</style>

<script>
    $(document).ready(function () {
        // Cuando se selecciona un archivo, se muestra su nombre
        $('#excelFileTeacher').change(function () {
            var fileName = $('#excelFileTeacher')[0].files[0].name;
            $('#fileNameDisplayTeacher').val(fileName);
        });

        $('#uploadBtnExcelTeacher').click(function () {
            var formData = new FormData();
            var fileInput = $('#excelFileTeacher')[0].files[0];

            if (!fileInput) {
                toastr.error('Por favor, seleccione un archivo.');
                return;
            }

            showGlobalLoadingIndicator();

            formData.append('excelFile', fileInput);

            $.ajax({
                url: '@Url.Action("CreateTeacherExcel", "InitData")',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    hideGlobalLoadingIndicator();

                    if (response.result) {
                        $.confirm({
                            icon: 'fa fa-check',
                            typeAnimated: true,
                            type: 'green',
                            title: '¡Correcto!',
                            content: response.data,
                            buttons: {
                                Ok: {
                                    text: 'Ok',
                                    action: function () {
                                        window.location.href = '/InitData';
                                    }
                                }
                            }
                        });
                    } else {
                        toastr.error(response.data, 'Error!');
                    }
                },
                error: function (xhr, status, error) {
                    hideGlobalLoadingIndicator();
                    toastr.error('Ocurrio un error. Intente nuevamente!', 'Error!');
                }
            });
        });

        $('#resetBtn').click(function () {
            $('#uploadFormTeacher')[0].reset();
            $('#fileNameDisplayTeacher').val('No hay archivo seleccionado');
            $('#resultTeacher').html('');
        });

        $('#downloadTemplateExcelTeacher').click(function () {
            window.location.href = '@Url.Action("DownloadTeacherTemplateExcel", "InitData")';
        });
    });
</script>
