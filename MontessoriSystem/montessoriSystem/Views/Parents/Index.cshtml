@using MontessoriSystem.Core.Application.ViewModels.User;
@using MontessoriSystem.Core.Application.ViewModels.Section;
@model SaveUserViewModel


@{
    ViewData["Title"] = "Users";
}

<div class="container mb-1">

    <div class="container-principal">

        <div class="btn-container">           

            <button type="button" id="newParent" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nuevo</button>
            <button type="button" disabled id="editParent" class="btn btn-warning"><i class="fa-solid fa-pen-to-square"></i> Editar</button>

        </div>
        <div id="gridContainerParents"></div>
    </div>
    

</div>


<script>

   
    var IdInstituParents = '@ViewBag.IdInstitu';
    var idUser='';

    $(document).ready(function () {
        GetDatosParentsJson()
    });

    //Cargar table listado estudiantes
    function GetDatosParentsJson() {

        $('#gridContainerParents').dxDataGrid({
            dataSource: {
                load: function () {
                    return $.ajax({
                        url: '@Url.Action("GetDatosUserJson", "Parents")',
                        data: { idInstitu: IdInstituParents },
                        dataType: "json"
                    });
                }
            },
             columnMinWidth: 160,
            paging: {
                pageSize: 10,
            },
            pager: {
                showPageSizeSelector: true,
                allowedPageSizes: [10, 25, 50, 100],
            },
            searchPanel: {
                visible: true,
                highlightCaseSensitive: true,
            }, scrolling: {
                mode: 'standard'
            },
            groupPanel: { visible: true },
            grouping: {
                autoExpandAll: false,
            },
            allowColumnReordering: true,
            keyExpr: 'ID',
            showColumnLines: true,
            showRowLines: true,
            rowAlternationEnabled: false,
            showBorders: true,
            hoverStateEnabled: true,
            selection: {
                mode: 'multiple',
            },
            width: '100%',
            columns: [
                {
                    dataField: 'firstName',
                    caption: "Nombre"
                },
                {
                    dataField: 'lastName',
                    caption: "Apellidos"
                },
                {
                    dataField: 'userName',
                    caption: "Nombre de Usuario"
                }, 
                {
                    dataField: 'sex',
                    caption: "Sexo"
                },
                {
                    dataField: 'dateBirth',
                    caption: "Fecha de nacimiento",
                    cellTemplate: function (container, options) {
                        var formattedDate = formatDateString(options.data.dateBirth);
                        $('<div>').text(formattedDate).appendTo(container);
                    }
                },{
                    dataField: '',
                    caption: "Edad",
                    cellTemplate: function (container, options) {
                        var formattedDate = GetCurrentAge(options.data.dateBirth);
                        $('<div>').text(formattedDate).appendTo(container);
                    }
                },
                {
                    dataField: 'relationship',
                    caption: "Parentesco"
                },
                {
                    dataField: 'identificationId',
                    caption: "Cédula de identidad"
                },
                {
                    dataField: 'civilStatusDesc',
                    caption: "Estado Civil"
                },
                {
                    dataField: 'nationalityDesc',
                    caption: "Nacionalidad"
                },
                 {
                    dataField: 'educationLevel',
                    caption: "Nivel educativo"
                },

                {
                    dataField: 'email',
                    caption: "Correo Eléctronico"
                },
                {
                    dataField: 'tel',
                    caption: "Número de Teléfono"
                },
                {
                    dataField: 'phoneNumber',
                    caption: "Número de Celular"
                },
                {
                    dataField: 'addres',
                    caption: "Dirección"
                },
                {
                    dataField: 'professionDesc',
                    caption: "Profesión"
                },
                {
                    dataField: 'jobDesc',
                    caption: "Trabajo"
                }
                ,
                {
                    dataField: 'placeWork',
                    caption: "Lugar de trabajo"
                },
                {
                    dataField: 'noBook',
                    caption: "No. Libro"
                },
                {
                    dataField: 'noFolio',
                    caption: "No. Folio"
                }

            ],
            onRowDblClick: function (e) {
                CreateUpdate();
            }, onRowClick: function (e) {
                idUser =e.data.id
                //activeBtn()
            },
            onSelectionChanged(selectedItems) {

                var selectedRowKeys = selectedItems.selectedRowKeys;
                if (selectedRowKeys.length === 1) {
                    idUser = selectedRowKeys[0].id;
                    activeBtn()
                } else {
                    disableBtn();
                }
            },
            onContentReady: function (e) {

            }
        });

    }
    


    //Functions    

    //Create

    $('#newParent').on('click', function () {
        deselectAllRows();
        disableBtn();
        idUser = '';        
        CreateUpdate('green', 'Crear');
    })
    $('#editParent').on('click', function () {
        deselectAllRows();
        disableBtn();
        CreateUpdate();
    })

    function CreateUpdate(type = 'green', title = 'Actualizar Datos') {

        $.ajax({
            url: '@Url.Action("CreateOrUpdate", "Parents")',
            method: 'GET',
            data: { idUser },
            success: function (data) {
                confirmDailog = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: title,
                    content: data,
                    type: type,
                    typeAnimated: true
                });
            }
        });

    }


    // btns Enable disable
    function activeBtn() {
        $('#editParent').prop("disabled", false);
        $('#deleteUser').prop("disabled", false);
    }

    function disableBtn() {
        $('#editParent').prop("disabled", true);
        $('#deleteUser').prop("disabled", true);
    }

    function refresshGridUsers() {
        
        $("#loadPanelContainer").dxLoadPanel("show");

        var dataGrid = $("#gridContainerParents").dxDataGrid("instance");
        dataGrid.refresh().done(function () {
            $("#loadPanelContainer").dxLoadPanel("hide");            
        });
    }

    function deselectAllRows() {
        var dataGrid = $('#gridContainerParents').dxDataGrid('instance');
        dataGrid.clearSelection();
    }

    if (IdInstituParents) {       
        var element = document.querySelector('.container-principal');
        element.style.boxShadow = 'initial';
        element.style.webkitBoxShadow = 'initial';
        element.style.border = 'initial';
    }

</script>

<style>

    
    .btn-container {
        display: flex;
        justify-content: end;
        padding-bottom: 10px;
        min-width: 200px;
    }

    .container-principal {
        background-color: white;
        border-radius: 5px;
        padding: 30px;
        margin-bottom: 30px;
        -webkit-box-shadow: 1px 1px 5px 0px rgba(0, 0, 0, 0.3);
        box-shadow: 1px 1px 5px 0px rgba(0, 0, 0, 0.3);
        border: 1px solid #ccd2d5;
    }

    #editParent {
        margin-left: 10px;
        margin-right: 10px;
    }

    #deleteUser {
        margin-left: 10px;
        margin-right: 10px;
    }

    
</style>

