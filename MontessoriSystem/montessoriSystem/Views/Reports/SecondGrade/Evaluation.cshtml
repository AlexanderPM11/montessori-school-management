@using MontessoriSystem.Core.Application.ViewModels.ObservationCommentEvaluation;
@model ObservationCommentEvaluationViewModel
@using MontessoriSystem.Core.Domain.Settings;
@using MontessoriSystem.Core.Application.Common;
@using MontessoriSystem.Core.Domain.Settings.Period;

@inject Microsoft.Extensions.Options.IOptions<EducationalPeriodCalifict> EducationalPeriodCalifict

@{
    string Agosto_Octubre = EducationalPeriodCalifict.Value.Agosto_Octubre;
    string Noviembre_Enero = EducationalPeriodCalifict.Value.Noviembre_Enero;
    string Febrero_Marzo = EducationalPeriodCalifict.Value.Febrero_Marzo;
    string Abril_Junio = EducationalPeriodCalifict.Value.Abril_Junio;

    var grades = ViewBag.Grade as List<ClassSelected<int>>;
}

<div class="select">

    <div class="container-select">
        <label for="period" class="form-label">Periodo</label>
        <select for="period" id="period-select" class="form-select col" aria-label="Default select example">
            <option value="@Agosto_Octubre">@Agosto_Octubre</option>
            <option value="@Noviembre_Enero">@Noviembre_Enero</option>
            <option value="@Febrero_Marzo">@Febrero_Marzo</option>
            <option value="@Abril_Junio">@Abril_Junio</option>
        </select>
    </div> 
    <div class="container-select">
        <label for="Asignatura" class="form-label">Asignatura</label>
        <select for="Asignatura" id="Asignatura-select" class="form-select col">
            @foreach (var grade in grades)
            {
                <option value="@grade.Id">@grade.text</option>
            }
         
        </select>
    </div>

    <div class="container-btn-preview-pdf">
        <button type="button" id="previewreportInfanteStudent" class="btn btn-info"><i class="fa-regular fa-file-pdf"></i>  Vista Previa</button>
    </div>

</div>

<div id="container-data-infante-report"></div>

<script>
    var selectedGradeId
    var selectedPeriod
    $(document).ready(function () {
        selectedGradeId = $('#Asignatura-select').val(); // 
        selectedPeriod = $('#period-select').val(); //

        // Función para actualizar los datos
        function updateData(period = "@Agosto_Octubre", gradeId = selectedGradeId) {
            $.ajax({
                url: '@Url.Action("GetDataReport", "Reports")',
                method: 'GET',
                data: { IdStudent: idStudent, period: period, IdSubject: gradeId },
                success: function (data) {
                    if (data.success !== undefined && !data.success) {
                        toastr.warning(data.message);
                        return;
                    }
                    $('#container-data-infante-report').empty();
                    $('#container-data-infante-report').html(data);
                }
            });
        }

        // Llamada inicial para cargar los datos con el valor predeterminado de la asignatura
        updateData();

        // Cuando se cambia el periodo
        $('#period-select').change(function () {
            selectedPeriod = $(this).val();
            updateData(selectedPeriod, selectedGradeId); // Actualiza los datos con el periodo seleccionado y la asignatura actual
        });

        // Cuando se cambia la asignatura
        $('#Asignatura-select').change(function () {
            selectedGradeId = $(this).val(); // Actualiza el ID de la asignatura seleccionada
            updateData($("#period-select").val(), selectedGradeId); // Actualiza los datos con el nuevo valor de asignatura y periodo actual
        });

        // Función para la vista previa del reporte
        $('#previewreportInfanteStudent').on('click', function () {
            previewreportInfante();
        });

        function previewreportInfante() {
            showGlobalLoadingIndicator();
            $.ajax({
                url: '@Url.Action("PreviewReport", "Reports")',
                method: 'GET',
                data: { IdStudent: idStudent, Period: selectedPeriod, IdSubject: selectedGradeId },
                xhrFields: {
                    responseType: 'arraybuffer'
                },
                success: function (data) {
                    hideGlobalLoadingIndicator();
                    var blob = new Blob([data], { type: 'application/pdf' });
                    var url = URL.createObjectURL(blob);

                    confirmDailog = $.confirm({
                        buttons: false,
                        boxWidth: '70%',
                        useBootstrap: false,
                        closeIcon: true,
                        title: `Vista Previa - ${fullNameStudent}`,
                        content: `<iframe src="${url}" width="100%" height="500px" style="border:none;"></iframe>`,
                        type: 'green',
                        onClose: function () {
                            URL.revokeObjectURL(url);
                        }
                    });
                },
                error: function (error) {
                    hideGlobalLoadingIndicator();
                    toastr.warning('El informe para este grado está en proceso de construcción y estará disponible próximamente. ¡Gracias por su paciencia!', 'Warning!');
                }
            });
        }
    });


</script>

<style>
    .container-btn-preview-pdf{
        margin-left:10px;
        margin-bottom: 20px;
    }
    .container-select {
        width: 60%;
        max-width: 350px;
        margin-bottom: 20px;
        margin-left:10px;
    }

    .select {
        width: 100%;
        display: flex;
        justify-content: end;
        align-content: end;
        align-items: end;
    }

    @@media (max-width: 968px) {
        .select {
            width: 100%;
            flex-direction:column;
            display: flex;
            justify-content: start;
            align-content: start;
            align-items: start;
        }

        .container-btn-preview-pdf {
            width: 100%;
            margin-left: 0px;
            margin-bottom: 20px;
        }
    }

</style>
