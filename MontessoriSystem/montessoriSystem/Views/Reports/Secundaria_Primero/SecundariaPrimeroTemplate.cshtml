                    </span>
                    Código
                    <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:150px;">
                        @Model.EducationalInstitutionViewModel.EducationalRegistry
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 20px; margin: 0;">
                    Tanda
                    <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:568px;">
                        @Model.EducationalInstitutionViewModel.Session
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 20px; margin: 0;">
                    Teléfono del centro
                     <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:456px;">
                        @Model.EducationalInstitutionViewModel.Phone
                    </span>
                </p>
            </div>
        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 20px; margin: 0;">
                    Regional
                    <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:300px;">
                        @Model.EducationalInstitutionViewModel.Regional
                    </span>
                    Distrito
                    <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:170px;">
                        @Model.EducationalInstitutionViewModel.District
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 20px; margin: 0;">
                    Nombres y apellidos del estudiante
                    <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:317px;">
                        @Model.StudentViewModel.Name  @Model.StudentViewModel.Lastname
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 20px; margin: 0;">
                    No. ID o Pasaporte
                    <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:450px;">
                        Sim implementar
                    </span>
                </p>
            </div>

        </div>

        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 20px; margin: 0;">
                    Sección
                    <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:210px;">
                        @Model.EducationalInstitutionViewModel.Session
                    </span>
                    No. orden en la lista
                    <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:150px;">
                        N/A
                    </span>
                </p>
            </div>

        </div>

        @* ----------------------------------------------------------------------------------------------- *@

        @* Presentación *@
        <div style="page-break-before: always;"></div>

        <div style="padding-left:80px;padding-right:80px; text-align: center; margin-top:0px; font-family: Arial, sans-serif; line-height: 1.5;">

            <div style="padding-top:100px; text-align:center;">

                <p style="font-weight: bold; font-size:35px; margin: 0;">Presentación</p>
                <p style="font-weight: bold; font-size: 17px;text-align:start !important;">
                    Estimados padres, madres y tutores:
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    El Ministerio de Educación de la República Dominicana ha generado profundas
                    transformaciones para impulsar las mejoras que se requieren en el proceso educativo. La
                    acción de educar de la nueva escuela del Nivel Secundario requiere de acciones colectivas:
                    el pacto familia-escuela es indisoluble para la formación de los adolescentes y jóvenes.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    Para lograr esos fines, les presentamos el informe de aprendizaje de sus hijos e hijas, para
                    que juntos acompañemos su trayectoria escolar, celebremos sus logros y superemos las
                    dificultades del proceso educativo convirtiéndolos en oportunidades de aprendizaje. Ser
                    garante de la calidad, es una meta común.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    El Informe de aprendizaje contiene las siete competencias específicas de cada asignatura
                    del conocimiento y hace referencia al conjunto de capacidades que van a desarrollar
                    sus hijos e hijas. Es importante conocer qué saberes han movilizado los estudiantes a
                    través de los desempeños, al entregar una evidencia, tomando en cuenta lo que conoce,
                    hace, así como sus valores y actitudes.  Fortalecemos estas dimensiones integrales para la
                    formación de mejores personas.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    Durante el año escolar en la evaluación formativa, las valoraciones de los aprendizajes se
                    traducirán en calificaciones parciales, las cuales se reportan en cuatro períodos como lo
                    establezca el calendario escolar, organizados de la siguiente manera:
                </p>

                <div style="padding-left:50px; text-align:start;">
                    <span>• P1= Primer reporte de evaluación</span><br />
                    <span>• P2= Segundo reporte</span><br />
                    <span>• P3= Tercer reporte</span><br />
                    <span>• P4= Cuarto reporte</span>
                </div>               

                <p style="font-size: 14px;text-align: justify;">
                    La valoración de las competencias específicas se realizará dentro de las casillas (P1, P2,
                    P3 y P4) con una calificación numérica de 0 a 100, en relación con el nivel de desempeño
                    logrado por el estudiante como resultado del proceso evaluativo en función al periodo o
                    ciclo formativo.
                </p>
                
            </div>            

        </div>

        @* -------Numero Page----------*@

        <div style="font-size:8px; position: relative; bottom: 0; right:0; width: 100%; text-align: right; font-family: Arial, sans-serif; padding: 10px; padding-top:220px; ">
            <span style="font-size:12px !important; padding-right:60px;">3</span>
            <div style="height:15px; width:65px; background-color:black; position: absolute; bottom: 10px;right:0;"></div>
        </div>
        <div style="page-break-before: always;"></div>


        <div style="padding-left:80px;padding-right:80px; text-align: center; margin-top:0px; font-family: Arial, sans-serif; line-height: 1.5;">

            <div style="padding-top:50px; text-align:center;">

                <p style="font-size: 14px;text-align: justify;">
                    Las calificaciones de las competencias específicas por debajo de 70 puntos serán
                    recuperadas a través de actividades complementarias o tutorías para que el estudiante
                    presente las evidencias de aprendizajes de los aspectos no alcanzados en los indicadores
                    de logro, que les permita el desarrollo de las competencias. Su contribución en estas
                    acciones favorece mejores resultados en los aprendizajes.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    Las calificaciones de los estudiantes que participan del proceso de recuperación pedagógica
                    (RP) se plasman en las casillas posteriores a los dos períodos correspondientes.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    La calificación final (CF) del estudiante en cada asignatura, es el resultado del promedio
                    ponderado de las competencias específicas. El mínimo aprobatorio para cada asignatura
                    es de 70 puntos.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    Los invitamos a ser partícipes de la nueva escuela del Nivel Secundario, una escuela que
                    acoge en la pluralidad y de forma tierna diseña junto a sus hijos e hijas su proyecto de vida
                    desde una visión personal y social.
                </p>

                <p style="font-size: 14px;text-align: justify;">
                    El Nivel Secundario aspira a cambiar la mirada hacia los aprendizajes, dignificar la labor
                    docente y resignificar la escuela desde los procesos evaluativos. Para lograr estas metas,
                    necesitamos del acompañamiento y del seguimiento de las familias, con el fin de conseguir
                    mejores resultados en el aprendizaje.
                </p>
                <p style="font-size: 14px;text-align: justify; font-style:italic;">
                    Dirección General de Educación Secundaria

                </p>

            </div>

        </div>
        @* -------Numero Page----------*@

        <div style="font-size:8px; position: relative; bottom: 0; right:0; width: 100%; text-align: right; font-family: Arial, sans-serif; padding: 10px; padding-top:488px; ">
            <span style="font-size:12px !important; padding-right:60px;">4</span>
            <div style="height:15px; width:65px; background-color:black; position: absolute; bottom: 10px;right:0;"></div>
        </div>

        @* ----------------------------------------------------------------------------------------------- *@
        @* Pagina #6 *@

        <div style="page-break-before: always;"></div>

        <div style="padding-left:40px;padding-right:30px; text-align: center; margin-top:5px; padding-top:20px; line-height: 1.5;">

            <div style="padding-top:00px; text-align:center;padding-left:7px;">

                <table border="1" style="border-collapse: collapse; width: 100%; font-family: Arial, sans-serif;">
                    
                    <thead>

                        <tr style="background-color: #4f4f4f; color: #fff;">
                            <th colspan="2" style="padding: 7px; text-align: center; width: 40%; font-size:15px;">COMPETENCIAS FUNDAMENTALES Y ESPECÍFICAS DE:</th>
                            <th colspan="8" style="text-align: center; width: 70%;">EVALUACIÓN</th>
                        </tr>

                        <tr >
                            <th rowspan="2" colspan="2" style="padding: 10px; text-align: left; width: 40%;  background-color: #d1d1d1;">Lengua Española</th>
                            
                            <th style="padding: 4px; width: 5%;">P1</th>
                            <th style="padding: 4px; width: 5%;">P2</th>

                            <th style="padding: 4px; width: 5%; background-color: #d1d1d1;">RP</th>

                            <th style="padding: 4px; width: 5%;">P3</th>
                            <th style="padding: 4px; width: 5%;">P4</th>
                            <th style="padding: 4px; width: 5%; background-color: #d1d1d1;">RP</th>

                            <th style="padding: 10px; width: 8%;">CF</th>
                            <th style="padding: 10px; width: 8%;">%A</th>
                        </tr>

                    </thead>

                    <tbody style="font-size:12px;">

                        @{
                            var modelsLenguEsp = Model.vmPrinc.Where(x => x.Indicator.CodeSubject.Equals("LENESP"));

                            // Variables para las calificaciones (nota) de cada materia
                            double LenguaCFE = 0;
                            double LenguaCComplet = 0;
                            double LenguaCExtr = 0;

                            double LenguasExtraIng = 0;
                            double LenguasExtraIngComplet = 0;
                            double LenguasExtraIngExtr = 0;

                            double LenguasExtraFranc = 0;
                            double LenguasExtraFrancComplet = 0;
                            double LenguasExtraFrancExtr = 0;

                            double MatemCFE = 0;
                            double MatemComplet = 0;
                            double MatemExtr = 0;

                            double CienciaSociCFE = 0;
                            double CienciaSociComplet = 0;
                            double CienciaSociCExtr = 0;

                            double CienciaNatuCFE = 0;
                            double CienciaNatuComplet = 0;
                            double CienciaNatuExtr = 0;

                            double EducaciFisiCFE = 0;
                            double EducaciFisiComplet = 0;
                            double EducaciFisiExtr = 0;

                            double EducaciArtiCFE = 0;
                            double EducaciArtiComplet = 0;
                            double EducaciArtiExtr = 0;

                            double IntegralHumanaCFE = 0;
                            double IntegralHumanaComplet = 0;
                            double IntegralHumanaExtr = 0;

                            int CountQuestionSubject = 0;

                        }

                        @foreach (var item in modelsLenguEsp)
                        {                            
                            var firstPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Agosto_Octubre));
                            var secondPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Noviembre_Enero));
                            var thirdPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Febrero_Marzo));
                            var fourPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Abril_Junio));

                            bool allPeriodCompleted = firstPeriod != null && secondPeriod != null && thirdPeriod != null && fourPeriod != null;
                            double average = 0;
                            double finalCalif = 0;

                            if (allPeriodCompleted)
                            {
                                // Si todos los períodos están completos, calculamos el average
                                var califications = new List<double>();
                                

                                califications.Add(firstPeriod.Calification);
                                califications.Add(secondPeriod.Calification);
                                califications.Add(thirdPeriod.Calification);
                                califications.Add(fourPeriod.Calification);
                               
                                // Calculamos el average si hay calificaciones disponibles
                                if (califications.Count > 0)
                                {
                                    finalCalif = califications.Sum();

                                    if (secondPeriod.RecuperaPedg > 0)
                                    {
                                        finalCalif = finalCalif + (secondPeriod.RecuperaPedg / 2) ?? 0;
                                        LenguaCComplet += secondPeriod.RecuperaPedg ?? 0;
                                    }
                                    if (fourPeriod.RecuperaPedg > 0)
                                    {
                                        LenguaCExtr += fourPeriod.RecuperaPedg ?? 0;
                                        finalCalif = finalCalif + Math.Round(fourPeriod.RecuperaPedg * 0.3 ?? 0, 2);
                                    }

                                    finalCalif = finalCalif / 4;

                                    LenguaCFE += finalCalif;
                                }
                            }

                            <tr>

                                <td style="padding: 10px; text-align:start;" colspan="2">
                                    @Html.Raw(item.Indicator.Description)
                                </td>

                                @if (firstPeriod != null)
                                {
                                    <td style="padding: 4px; text-align: center;">
                                        @firstPeriod.Calification
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;"></td>
                                }

                                @if (secondPeriod != null)
                                {
                                    <td style="padding: 4px; text-align: center;">
                                        @secondPeriod.Calification
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;"></td>
                                }

                                @if (secondPeriod != null && secondPeriod.RecuperaPedg > 0)
                                {
                                    <td style="padding: 4px; text-align: center; background-color: #d1d1d1;">
                                        @((secondPeriod.RecuperaPedg / 2)?.ToString("F2"))
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;background-color: #d1d1d1;"></td>
                                }


                                @if (thirdPeriod != null)
                                {
                                    <td style="padding: 4px; text-align: center;">
                                        @thirdPeriod.Calification
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;"></td>
                                }

                                @if (fourPeriod != null)
                                {
                                    <td style="padding: 4px; text-align: center;">
                                        @fourPeriod.Calification
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;"></td>
                                }

                                @if (fourPeriod != null && fourPeriod.RecuperaPedg > 0)
                                {
                                    <td style="padding: 4px; text-align: center; background-color: #d1d1d1;">
                                        @((fourPeriod.RecuperaPedg * 0.3)?.ToString("F2"))
                                    </td>
                                }
                                else
                                {
                                    <td style="padding: 4px; text-align: center;background-color: #d1d1d1;"></td>
                                }

                                @if (allPeriodCompleted)
                                {   
                                    <td style="padding: 10px; text-align: center;">@finalCalif.ToString("F2")</td>
                                }
                                else
                                {
                                    <td style="padding: 10px; text-align: center;"></td>
                                }

                                @if (allPeriodCompleted)
                                {
                                    <td style="padding: 10px; text-align: center;">@finalCalif.ToString("F2")</td>
                                }
                                else
                                {
                                    <td style="padding: 10px; text-align: center;"></td>
                                }

                            </tr>

                            CountQuestionSubject++;

                        }
                        @{
                            LenguaCFE = (LenguaCFE / CountQuestionSubject);
                            LenguaCComplet = (LenguaCComplet / CountQuestionSubject);
                            LenguaCExtr = (LenguaCExtr / CountQuestionSubject);
                        }

                    </tbody>

                </table>

            </div>

        </div>

        @* -------Numero Page----------*@

        <div style="font-size:8px; position: relative; bottom: 0; right:0; width: 100%; text-align: right; font-family: Arial, sans-serif; padding: 10px; padding-top:100px; ">
            <span style="font-size:12px !important; padding-right:60px;">5</span>
            <div style="height:15px; width:65px; background-color:black; position: absolute; bottom: 10px;right:0;"></div>
        </div>

        @* ----------------------------------------------------------------------------------------------- *@
        @* Pagina #7 *@

        <div style="page-break-before: always;"></div>

        <div style="padding-left:40px;padding-right:30px; text-align: center; margin-top:5px; padding-top:20px; line-height: 1.5;">

            <div style="padding-top:00px; text-align:center;padding-left:7px;">

                <table border="1" style="border-collapse: collapse; width: 100%; font-family: Arial, sans-serif;">

                    <thead>

                        <tr style="background-color: #4f4f4f; color: #fff;">
                            <th colspan="2" style="padding: 7px; text-align: center; width: 40%; font-size:15px;">COMPETENCIAS FUNDAMENTALES Y ESPECÍFICAS DE:</th>
                            <th colspan="8" style="text-align: center; width: 70%;">EVALUACIÓN</th>
                        </tr>

                        <tr>
                            <th rowspan="2" colspan="2" style="padding: 10px; text-align: left; width: 40%;  background-color: #d1d1d1;">Lenguas Extranjeras: Inglés</th>

                            <th style="padding: 4px; width: 5%;">P1</th>
                            <th style="padding: 4px; width: 5%;">P2</th>

                            <th style="padding: 4px; width: 5%; background-color: #d1d1d1;">RP</th>

                            <th style="padding: 4px; width: 5%;">P3</th>
                            <th style="padding: 4px; width: 5%;">P4</th>
                            <th style="padding: 4px; width: 5%; background-color: #d1d1d1;">RP</th>

                            <th style="padding: 10px; width: 8%;">CF</th>
                            <th style="padding: 10px; width: 8%;">%A</th>
                        </tr>

                    </thead>

                    <tbody style="font-size:12px;">

                        @{
                            CountQuestionSubject = 0;
                            var modelsIngles = Model.vmPrinc.Where(x => x.Indicator.CodeSubject.Equals("ING"));
                        }

                        @foreach (var item in modelsIngles)
                        {
                            var firstPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Agosto_Octubre));
