        @* Anio escolar *@
        <div style="position:absolute; top:860px; left:278px;font-style:italic;">
            <p>@((DateTime.Now.Year-1).ToString().Substring(2))</p>
        </div>
        <div style="position:absolute; top:860px; left:358px; font-style:italic;">
            <p>@DateTime.Now.Year.ToString().Substring(2)</p>
        </div>
        @* --------------------------------------- *@
        @* Anio escolar *@
        <div style="position:absolute; top:915px; left:200px;font-style:italic;">
            <p>Sim implementar N/A</p>
        </div>
       
        @* --------------------------------------- *@

        <div style ="width:100%">
            <img src="@imgHead2" />
        </div>

        <br />
        <span style="width:100%; font-size:10px; font-weight:100;">GOBIERNO DE LA</span>

        <br />
        <span style="width:100%; font-size:16px; font-weight:300;">REPÚBLICA DOMINICANA</span>
        <div class="container-linea" style="width: 100%; display: flex; align-items: center; justify-content: center; margin-top:5px; margin-bottom:5px;">
            <div style="width: 85px; height: 3px; background-color: #3d3d3d; margin: 0 auto;"></div>
        </div>

        <span style="width:100%; font-size:16px; font-weight:300;">EDUCACIÓN</span>

        @* Reporte para las familias *@

        <div style="width:100%;display:flex;  justify-content:center; margin-top:15px;">
            <div style="width:400px; font-size:32px; font-weight:bold; text-align:center; width:650px; margin: 0 auto;  line-height: 1.5;">
                <p>
                    Informe de Evaluación <br />  <span style="font-size:23px;">de los Aprendizajes</span> 
                </p>

            </div>
        </div>

        <div style="width:100%; padding:0px !important;margin:0px !important;">
            <img style="height:200px !important;width:300px !important; padding:0px !important; margin:0px !important;" src="data:image/png;base64, " />
        </div>
       
        <div style="width: 100%; display: flex; justify-content: center; margin-top: 20px;">

            <div style="margin-left: 90px; margin-right: 90px; text-align: start;">
                <p style="font-size: 20px; margin: 0;">
                    Centro Educativo
                    <span style="border-bottom:2px solid rgb(70, 69, 69); margin-left: 5px; font-style:italic;font-size: 16px; display: inline-block; width:240px;">
