                            <th style="padding: 4px; width: 5%; background-color: #d1d1d1;" rowspan="2">RP</th>

                            <th style="padding: 4px; width: 5%;" rowspan="2">P3</th>
                            <th style="padding: 4px; width: 5%;" rowspan="2">P4</th>
                            <th style="padding: 4px; width: 5%; background-color: #d1d1d1;" rowspan="2">RP</th>

                            <th style="padding: 10px; width: 8%;" rowspan="2">CF</th>
                            <th style="padding: 10px; width: 8%;" rowspan="2">%A</th>
                        </tr>

                    </thead>

                    <tbody style="font-size:12px;">

                        @{
                            var modelsFORINTHUMYREL = Model.vmPrinc.Where(x => x.Indicator.CodeSubject.Equals("FORINTHUMYREL"));
                            CountQuestionSubject = 0;

                        }

                        @foreach (var item in modelsFORINTHUMYREL)
                        {
                            var firstPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Agosto_Octubre));
                            var secondPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Noviembre_Enero));
                            var thirdPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Febrero_Marzo));
                            var fourPeriod = item.PeriodosEstados.FirstOrDefault(x => x.Periodo.Equals(Abril_Junio));

                            bool allPeriodCompleted = firstPeriod != null && secondPeriod != null && thirdPeriod != null && fourPeriod != null;
                            double average = 0;
                            double finalCalif = 0;

                            if (allPeriodCompleted)
                            {
                                // Si todos los períodos están completos, calculamos el average
                                var califications = new List<double>();

                                califications.Add(firstPeriod.Calification);
                                califications.Add(secondPeriod.Calification);
                                califications.Add(thirdPeriod.Calification);
                                califications.Add(fourPeriod.Calification);

                                // Calculamos el average si hay calificaciones disponibles

                                if (califications.Count > 0)
                                {

                                    finalCalif = califications.Sum();

                                    if (secondPeriod.RecuperaPedg > 0)
                                    {
                                        finalCalif = finalCalif + (secondPeriod.RecuperaPedg / 2) ?? 0;
                                        IntegralHumanaComplet += secondPeriod.RecuperaPedg ?? 0;

                                    }
                                    if (fourPeriod.RecuperaPedg > 0)
                                    {
                                        finalCalif = finalCalif + Math.Round(fourPeriod.RecuperaPedg * 0.3 ?? 0, 2);
                                        IntegralHumanaExtr += fourPeriod.RecuperaPedg ?? 0;

                                    }

                                    finalCalif = finalCalif / 4;
                                    IntegralHumanaCFE += finalCalif;
                                }
                            }

                            <tr>

                                <td style="padding: 10px; text-align:start;" colspan="2">
                                    @Html.Raw(item.Indicator.Description)
                                </td>

                                @if (firstPeriod != null)
                                {
                                    <td style="padding: 4px; text-align: center;">
                                        @firstPeriod.Calification
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;"></td>
                                }

                                @if (secondPeriod != null)
                                {
                                    <td style="padding: 4px; text-align: center;">
                                        @secondPeriod.Calification
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;"></td>
                                }

                                @if (secondPeriod != null && secondPeriod.RecuperaPedg > 0)
                                {
                                    <td style="padding: 4px; text-align: center; background-color: #d1d1d1;">
                                        @((secondPeriod.RecuperaPedg / 2)?.ToString("F2"))
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;background-color: #d1d1d1;"></td>
                                }


                                @if (thirdPeriod != null)
                                {
                                    <td style="padding: 4px; text-align: center;">
                                        @thirdPeriod.Calification
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;"></td>
                                }

                                @if (fourPeriod != null)
                                {
                                    <td style="padding: 4px; text-align: center;">
                                        @fourPeriod.Calification
                                    </td>
                                }
                                else
                                {
                                    <td style="padding:4px; text-align: center;"></td>
                                }

                                @if (fourPeriod != null && fourPeriod.RecuperaPedg > 0)
                                {
                                    <td style="padding: 4px; text-align: center; background-color: #d1d1d1;">
                                        @((fourPeriod.RecuperaPedg * 0.3)?.ToString("F2"))
                                    </td>
                                }
                                else
                                {
                                    <td style="padding: 4px; text-align: center;background-color: #d1d1d1;"></td>
                                }

                                @if (allPeriodCompleted)
                                {
                                    <td style="padding: 10px; text-align: center;">@finalCalif.ToString("F2")</td>
                                }
                                else
                                {
                                    <td style="padding: 10px; text-align: center;"></td>
                                }

                                @if (allPeriodCompleted)
                                {
                                    <td style="padding: 10px; text-align: center;">@finalCalif.ToString("F2")</td>
                                }
                                else
                                {
                                    <td style="padding: 10px; text-align: center;"></td>
                                }

                            </tr>

                            CountQuestionSubject++;
                        }
                        @{
                            IntegralHumanaCFE = (IntegralHumanaCFE / CountQuestionSubject);
                            IntegralHumanaComplet = (IntegralHumanaComplet / CountQuestionSubject);
                            IntegralHumanaExtr = (IntegralHumanaExtr / CountQuestionSubject);
                        }
                    </tbody>

                </table>

