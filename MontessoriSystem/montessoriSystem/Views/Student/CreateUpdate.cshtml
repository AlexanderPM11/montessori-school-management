    $(document).ready(function () {

        ValidateInputsStu()

    });  

    function guardarDatosStdent(){

        var formData = new FormData($('#formCreateUpdateStudent')[0]);

        
        var fileInput = $('#fileInput')[0].files[0];
        formData.append('File', fileInput);

        // Agregar idInstitu al objeto FormData
        const serializedValues = serializeValuesAgesSiblings();
        formData.append('IdInstitu', idInstituMain);
        if (typeof idRoomSelect !== 'undefined') {
            formData.append('IdRoom', idRoomSelect);
        }
        
        formData.append('AgesSiblings', serializedValues);

         $.ajax({
            url: '@Url.Action("CreateUpdateStudent", "Student")',
          method: 'POST',
          data:formData,
            processData: false,
            contentType: false,
          success: function (data) {        
              hideGlobalLoadingIndicator()
              toastr.success('Proceso realizado con exito!', 'Correcto!');
              
              if (IsPrincipalMain === "True"){
                  refresshGrid();
              }
              else {
                   refresshStudentParent();
              }
              
               confirmDailog.close();
          },
          error: function (error) {
              hideGlobalLoadingIndicator()
              toastr.error('Ocurrio un error. Intente nuevamente!', 'Error!')
                }
          });
    }

    function getDataAdjunto(){
        $.ajax({
            url: 'Adjunto/PartialViewAdjunto',
            method: 'GET',
            data:{idStudent},
            success: function (data) {
                $("#display-tab2").html(data);
            },
            error: function (error) {
                console.error('Error al obtener datos:', error);
            }
        });
    }

    $("#btn-save-student").click(function(){
        
        if ($('#formCreateUpdateStudent').valid()) {
            showGlobalLoadingIndicator()
            guardarDatosStdent();
        } else{
          return false;
        }
    }); 
   
    $("#btn-cancel").click(function(){
        confirmDailog.close();
    });

    function previewImage(event) {
        const file = event.target.files[0];
        const reader = new FileReader();
        const indicator = document.querySelector('.file-indicator'); // Selecciona el mensaje indicativo

        reader.onload = function () {
            const imgElement = document.getElementById('image-student');
            const ContainerimgElement = document.getElementById('image-student');
            
            imgElement.src = reader.result; // Actualiza la fuente de la imagen
            indicator.style.display = 'none'; // Oculta el mensaje indicativo
            ContainerimgElement.style.border = 'none';
        };

        if (file) {
            reader.readAsDataURL(file); // Lee el archivo como una URL de datos
        }
    }

</script>

