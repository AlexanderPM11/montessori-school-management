<script>
    function hideFileInput() {

        const imgElement = document.getElementById('image-student');

        if ( "@Model.UrlImg" !== "") {
            const indicator = document.querySelector('.file-indicator');
            const ContainerimgElement = document.getElementById('image-student');

            indicator.style.display = 'none'; // Oculta el mensaje indicativo
            ContainerimgElement.style.border = 'none';
        }
        
    }
    hideFileInput();

    // Auto-generated numbers siblings

    var agesSiblings = "@Model.AgesSiblings" 
    generateAgeFields()

    function generateAgeFields() {
        const numSiblings = document.getElementById("NumberSiblings").value;
        const ageFieldsContainer = document.getElementById("age_fields_container");

        // Limpiar los campos de edad existentes
        ageFieldsContainer.innerHTML = "";

        for (let i = 0; i < numSiblings; i++) {
            const colDiv = document.createElement("div");
            colDiv.className = "col-md-3 mb-3";

            const label = document.createElement("label");
            label.for = `sibling_age_${i}`;
            label.className = "form-label";
            label.innerHTML = `Edad hermano(a) ${i + 1}:<span style="color:red"> *</span>`;

            const input = document.createElement("input");
            input.type = "text"; // Se deja como text para validación numérica
            input.id = `sibling_age_${i}`;
            input.name = `sibling_ages[]`;
            input.className = "form-control";
            input.maxLength = "2";

            colDiv.appendChild(label);
            colDiv.appendChild(input);
            ageFieldsContainer.appendChild(colDiv);

            setTimeout(function () {
                $('#formCreateUpdateStudent').validate({});
                restrictInputToNumbers(`sibling_age_${i}`);
            }, 1000);
           

        }
    }
    
    function setAgeFieldsValues() {
        const valuesArray = decodeURIComponent(agesSiblings.replace(/&amp;/g, '&')).split('&');
        const ageFieldsContainer = document.getElementById("age_fields_container");
        const inputs = ageFieldsContainer.querySelectorAll('input[type="text"]');

        inputs.forEach((input, index) => {
            if (valuesArray[index] !== undefined) {
                input.value = valuesArray[index];
            }
        });
    }
    
    setAgeFieldsValues();

    $("#NumberSiblings").on('input', generateAgeFields)
        
    function serializeValuesAgesSiblings() {
        const ageInputs = document.querySelectorAll('#age_fields_container input[type="text"]');
        let serializedData = [];

        ageInputs.forEach(input => {
            const value = input.value.trim(); // Obtener el valor y eliminar espacios en blanco al inicio y al final

            if (value !== "") { // Verificar si el valor no está vacío
                serializedData.push(encodeURIComponent(value));
            }
        });

        return serializedData.join('&');
    }

