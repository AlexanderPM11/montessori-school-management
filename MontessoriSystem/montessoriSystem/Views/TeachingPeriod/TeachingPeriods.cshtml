
<div class="text-center">   

    <div class="btn-container">
        <button type="button" id="btnNewsTeachinPer" class="btn btn-success"><i class="fa-solid fa-plus"></i> Nuevo</button>
        <button type="button" disabled id="btnEditTeachinPer" class="btn btn-warning"><i class="fa-solid fa-pen-to-square"></i> Editar</button>
        <button type="button" disabled id="btnDeleteTeachinPer" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Eliminar</button>
    </div>
    <div id="gridContainerTeachingPeriods">

    </div>


</div>

<script>
    function formatDate(dateString) {
        var options = { day: '2-digit', month: '2-digit', year: 'numeric' };
        var date = new Date(dateString);
        return date.toLocaleDateString('es-ES', options);
    }
    $(document).ready(function () {
       
        GetTeachingPeriodsJson()
    });

    var idInstituSend = @ViewBag.idInstitu
    var idSelectTeachingPeri = 0;

    function GetTeachingPeriodsJson() {       
        
        $('#gridContainerTeachingPeriods').dxDataGrid({
            dataSource: {
                load: function () {
                    return $.ajax({
                        url: '@Url.Action("GetTeachingPeriodsJson", "TeachingPeriod")',
                        data: { idInstitu: idInstituSend }, 
                        dataType: "json"
                    });
                }
            },
            paging: {
                pageSize: 10,
            },
            pager: {
                showPageSizeSelector: true,
                allowedPageSizes: [10, 25, 50, 100],
            },
            searchPanel: {
                visible: true,
                highlightCaseSensitive: true,
            }, scrolling: {
                mode: 'standard', // 'virtual' o 'standard'
                // Otros ajustes de desplazamiento si es necesario
            },
            groupPanel: { visible: true },
            grouping: {
                autoExpandAll: false,
            },
            allowColumnReordering: true,
            keyExpr: 'ID',
            showColumnLines: true,
            showRowLines: true,
            rowAlternationEnabled: false,
            showBorders: true,
            hoverStateEnabled: true,
            selection: {
                mode: 'multiple',
            },
            width: '100%',
            columns: [
                {
                    dataField: 'name',
                    caption: "Nombre"
                }
                ,
                {
                    dataField: 'description',
                    caption: "Descripción"
                }
                ,
                {
                    dataField: 'dateInit',
                    caption: "Fecha de Inicio",
                        dataType: 'date',
                    format: 'dd MMMM yyyy'
                },
                {
                    dataField: 'dateFinish',
                    caption: "Fecha Finalización",
                    dataType: 'date',
                    format: 'dd MMMM yyyy'
                }

            ],
            onRowDblClick: function (e) {
                CreateUpdateTeachingPer();
            },
            onRowClick: function (e) {
                idSelectTeachingPeri = e.data.id;
            },
            onSelectionChanged(selectedItems) {
                var selectedRowKeys = selectedItems.selectedRowKeys;
                if (selectedRowKeys.length === 1) {
                    idSelectTeachingPeri = selectedRowKeys[0].id;
                    activeBtn();
                } else {
                    disableBtn();
                }
            },
        });

    }

    function CreateUpdateTeachingPer() {
        
        $.ajax({
            url: '@Url.Action("CreateUpdate", "TeachingPeriod")',
            method: 'GET',
            data: { id: idSelectTeachingPeri },
            success: function (data) {
                confirmDailog = $.confirm({
                    buttons: false,
                    boxWidth: '70%',
                    useBootstrap: false,
                    closeIcon: true,
                    title: '',
                    content: data,
                    type: 'green',
                    typeAnimated: true
                });
            }
        });

    }

    // Btns actions
    $("#btnNewsTeachinPer").click(function (event) {
        event.preventDefault();
        idSelectTeachingPeri = 0;
        CreateUpdateTeachingPer();
    });

    $("#btnEditTeachinPer").click(function (event) {
        CreateUpdateTeachingPer();
        disableBtn();

    });
    $("#btnDeleteTeachinPer").click(function (event) {
        deleteTeachingPer();
        disableBtn();

    });

    function refresshGridTeachingPeriods() {
        var dataGrid = $("#gridContainerTeachingPeriods").dxDataGrid("instance");
        dataGrid.refresh();
    }

    function deleteTeachingPer() {

        $.confirm({
            typeAnimated: true,
            type: 'red',
            title: 'Confirmar',
            content: 'Se va a eliminar este Periodo Lectivo. Desea continuar?',
            buttons: {
                Continuar: {
                    text: 'Continuar',
                    btnClass: 'btn-red',
                    action:  function () {
                    showGlobalLoadingIndicator()
                       
                    $.ajax({
                            url: '@Url.Action("Delete", "TeachingPeriod")',
                        method: 'Post',
                            data: { id: idSelectTeachingPeri },
                        success: function (data) {
                            hideGlobalLoadingIndicator();
                            if (data.result) {
                                toastr.success(data.data, 'Correcto!');
                                refresshGridTeachingPeriods();
                            } else {
                                toastr.error(data.data, 'Error!');
                            }
                           
                        }
                    });
                }
                },
                Cancelar: {
                    text: 'Cancelar',
                    btnClass: 'btn-default',  // Clase de Bootstrap para el botón "Cancelar"
                    action: function () {
                        // Lógica para cancelar
                    }
                }
            }
        });
    }



    function activeBtn() {
        $('#btnEditTeachinPer').prop("disabled", false);
        $('#btnDeleteTeachinPer').prop("disabled", false);
    }

    function disableBtn() {
        $('#btnEditTeachinPer').prop("disabled", true);
        $('#btnDeleteTeachinPer').prop("disabled", true);
    }


</script>

<style>
    .btn-container {
        display: flex;
        justify-content: end;
        padding-bottom: 10px;
        min-width: 200px;
        margin-right: 10px;
        margin-top: 10px;
        /* margin-top: 30px; */
    }


    #btnEditTeachinPer {
        margin-left: 10px;
        margin-right: 10px;
    }

</style>
