        display: flex;
        justify-content: center;
        width: 150px;
        height: 150px;
        padding: 0;
        border: 2px dashed #ccc;
        border-radius: 50%;
        cursor: pointer;
        text-align: center;
        background-color: #f9f9f9;
        position: relative;
        z-index: 1;
        overflow: hidden;
    }

    .file-message {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2;
        pointer-events: none;
    }

    .rounded-image {
        width: 100%;
        height: 100% !important;
        border-radius: 50%;
        object-fit: cover; /* Asegura que la imagen se ajuste dentro del contenedor circular */
    }

    .container-img {
        /* justify-content:start !important;  */
    }




    .container-lable-image{
        text-align:center;
    }
    .file-message {
        font-size: 16px;
        color: #555;
    }

    

    .container-img {
        justify-content: center;
        display: flex;
        min-width: 250px;
    }
    .container-btn{
        margin-top:30px;
        margin-right:30px;
        margin-bottom:10px;
        width:100%;
        display: flex;
        justify-content: end;
        right: 215px;
    }
    #btn-save-user{
        margin-right:10px;
    }

    .jconfirm-box {
        max-width: 1000px !important; /* Establecer ancho máximo */
    }

    #radio-no {
        margin-left: 30px;
    }

    .form-check {
        padding-left: 1.6rem !important;
    }
</style>

